PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/dating_app
# Optional alias used by many hosting platforms
# MONGODB_URI=mongodb://127.0.0.1:27017/dating_app
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
OTP_TTL_MINUTES=5
CLIENT_ORIGIN=http://localhost:3000
MONGO_CONNECT_RETRIES=5
MONGO_RETRY_DELAY_MS=2000
MONGO_FORCE_IPV4=true